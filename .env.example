DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
DJANGO_CSRF_TRUSTED_ORIGINS=

# Local fallback database. Used only when DATABASE_URL and POSTGRES_DB are empty.
SQLITE_NAME=db.sqlite3

# PostgreSQL. Use DATABASE_URL in production when your host provides one.
# Local example:
# DATABASE_URL=postgres://luiza:sua-senha@localhost:5433/lecto_db
# Render example:
# DATABASE_URL=postgresql://user:password@host:5432/database
# Or configure the same connection with separate variables:
# POSTGRES_DB=lecto
# POSTGRES_USER=lecto_user
# POSTGRES_PASSWORD=strong-password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Optional production hardening.
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=0

# Only needed when using the AI image generation command.
OPENAI_API_KEY=
